{
  "phase": "7E",
  "description": "WhatsApp real + GHL live + custom fields + academic-engine",
  "endpoint": "https://ernkyni3.us-east.insforge.app/functions/ycloud-wa-inbound",
  "from": "+529991525583",
  "to": "+529994538421",
  "required_runtime_flags": {
    "mode": "live_outbound",
    "outbound_real": true,
    "ghl_live": true,
    "ghl_synced": true,
    "ghl_dry_run": false,
    "custom_fields_written": true,
    "academic_engine_enabled": true,
    "eva_llm_enabled": false
  },
  "ghost_careers": ["contaduría", "contaduria", "arquitectura", "criminología", "criminologia", "diseño", "diseno", "educación", "educacion"],
  "banned_claims": ["nasa", "space apps", "7 países", "7 paises"],
  "wa_custom_field_keys": [
    "wa_last_intent",
    "wa_last_message_at",
    "wa_stage",
    "wa_needs_human",
    "wa_summary",
    "wa_source",
    "wa_last_inbound_text",
    "wa_last_outbound_text"
  ],
  "cases": [
    {
      "id": 1,
      "input": "1",
      "expect_wa_intent": "carreras_disponibles",
      "expect_academic_intent": "career_list",
      "expect_academic_enriched": true,
      "expect_ghl_tag": "wa_interes_carreras",
      "expect_task": false,
      "response_must_include": ["opciones oficiales"],
      "response_must_not_include": ["contaduría", "arquitectura", "criminología", "diseño", "educación"]
    },
    {
      "id": 2,
      "input": "Derecho online",
      "expect_wa_intent": "carrera_interes",
      "expect_academic_intent": "career_detail",
      "expect_academic_enriched": true,
      "expect_ghl_tag": "wa_interes_carrera",
      "expect_task": false,
      "response_must_include": ["Derecho", "línea", "1,980"]
    },
    {
      "id": 3,
      "input": "Tengo promedio 9.8, qué beca me toca",
      "expect_wa_intent": "beca",
      "expect_academic_intent": "scholarship",
      "expect_academic_enriched": true,
      "expect_ghl_tag": "wa_interes_beca",
      "expect_task": true,
      "response_must_include": ["50%", "inscripción", "validación"]
    },
    {
      "id": 4,
      "input": "No sé qué estudiar",
      "expect_wa_intent": "no_se_que_estudiar",
      "expect_academic_enriched": false,
      "expect_academic_skipped": true,
      "expect_ghl_tag": "wa_interes_test",
      "expect_task": false,
      "response_must_include": ["test vocacional"],
      "response_must_not_include": ["opciones oficiales"]
    },
    {
      "id": 5,
      "input": "Quiero hablar con asesor",
      "expect_wa_intent": "humano",
      "expect_academic_enriched": false,
      "expect_academic_skipped": true,
      "expect_ghl_tag": "wa_requiere_asesor",
      "expect_task": true,
      "response_must_include": ["canalizar con un asesor"],
      "response_must_not_include": ["opciones oficiales"]
    }
  ]
}
